{
  "name": "RetailFlow Executive Theme",
  "dataColors": [
    "#14B8A6",
    "#334155",
    "#22C55E",
    "#EF4444",
    "#0F172A",
    "#94A3B8"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#14B8A6",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontSize": 14,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#334155" } },
            "fontSize": 11
          }
        ],
        "background": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontSize": 16
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#334155" } }
          }
        ]
      }
    }
  }
}